---
import GithubIcon from "./icons/GithubIcon.astro";
import RssIcon from "./icons/RssIcon.astro";
import ExternalLinkIcon from "./icons/ExternalLinkIcon.astro";

const lang = Astro.currentLocale || "ko";
---

<footer class="bg-background-footer text-footer py-16">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <div
        class="flex flex-wrap items-center justify-center gap-4 text-xs text-text-muted md:justify-start md:gap-6"
      >
        <p>© 2026 naviary All rights reserved.</p>
        <a
          href="https://naviary.io"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-600 px-3 py-1 font-medium text-zinc-400 transition-colors hover:border-primary hover:text-primary"
          aria-label={lang === "ko"
            ? "Naviary 브랜드 페이지 새 탭으로 열기"
            : "Open Naviary brand page in a new tab"}
        >
          <span>Naviary.io</span>
          <ExternalLinkIcon className="size-3.5" />
        </a>
      </div>
      <div class="flex items-center gap-6">
        <a
          class="hover:text-primary transition-colors"
          href={`/${lang}/rss.xml`}
          title="RSS Feed"
        >
          <RssIcon />
        </a>
        <GithubIcon className="hover:text-primary transition-colors" />
      </div>
    </div>
  </div>
</footer>
