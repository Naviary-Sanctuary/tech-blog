---
import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"ul"> {}
const { class: className, ...rest } = Astro.props;
---

<ul
  {...rest}
  data-list-type="ul"
  class:list={[
    "list-none space-y-2 my-6",
    "[&>li]:before:content-[''] [&>li]:before:absolute [&>li]:before:left-2 [&>li]:before:top-[0.8em] [&>li]:before:w-1.5 [&>li]:before:h-1.5 [&>li]:before:rounded-full [&>li]:before:bg-zinc-300",
    "[&_ol]:my-2 [&_ul]:my-2",
    className,
  ]}
>
  <slot />
</ul>
