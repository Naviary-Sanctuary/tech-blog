---
interface Props {
  currentPage: number;
  totalPage: number;
}

const currentHref = Astro.url.pathname;
const { currentPage, totalPage } = Astro.props;

const normalizePath = (path: string) => {
  if (path === "/") return "/";
  const cleaned = path.replace(/^\/+|\/+$/g, "");
  return `/${cleaned}`;
};

const toPageHref = (page: number) => {
  const normalizedPath = normalizePath(currentHref);
  const basePath = normalizedPath.replace(/\/\d+$/, "") || "/";
  const targetPath = page === 1 ? basePath : `${basePath}/${page}`;
  return targetPath === "/" ? "/" : `${targetPath}/`;
};

const pages = Array.from({ length: totalPage }, (_, index) => {
  const page = index + 1;
  return { page, href: toPageHref(page) };
});
---

<nav class="flex items-center justify-center gap-2">
  {
    pages.map((page) => (
      <a
        href={page.href}
        aria-current={page.page === currentPage ? "page" : undefined}
        class={`flex items-center justify-center size-10 rounded-lg text-sm font-medium transition-colors ${
          page.page === currentPage
            ? "bg-primary text-white"
            : "text-zinc-700 hover:bg-tertiary/2 hover:text-primary"
        }`}
      >
        {page.page}
      </a>
    ))
  }
</nav>
